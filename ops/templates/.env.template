# =====================================================================
# leCRM — per-client environment template
# =====================================================================
# Rendered by ops/provision-client.sh into:
#   ops/clients/<client-slug>/.env
# Treat the rendered file as a SECRET — `.gitignore` excludes
# `ops/clients/` from git.
# =====================================================================

# Identity
CLIENT_SLUG=__SLUG__
CLIENT_SUBDOMAIN=__SUBDOMAIN__

# Image (override only when testing a non-default tag)
LECRM_IMAGE=ghcr.io/elgui/lecrm:twenty-2.2.0-lecrm.0

# Postgres
PG_DATABASE_NAME=lecrm___SLUG_UNDERSCORE__
PG_DATABASE_USER=lecrm___SLUG_UNDERSCORE__
PG_DATABASE_PASSWORD=__GENERATED_PG_PASSWORD__

# App secret (rotate per deployment)
APP_SECRET=__GENERATED_APP_SECRET__

# Email — Brevo SMTP (transactional)
EMAIL_FROM_ADDRESS=no-reply@__CLIENT_DOMAIN__
EMAIL_FROM_NAME=__CLIENT_NAME__ via leCRM
BREVO_SMTP_LOGIN=__BREVO_SMTP_LOGIN__
BREVO_SMTP_KEY=__BREVO_SMTP_KEY__

# OIDC — Google Workspace defaults; override for Microsoft Entra ID clients
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=__OIDC_CLIENT_ID__
OIDC_CLIENT_SECRET=__OIDC_CLIENT_SECRET__
