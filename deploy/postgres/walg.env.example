# WAL-G environment template — OVH Object Storage (S3-compatible).
#
# Copy to deploy/postgres/walg.env and encrypt with SOPS before
# committing (see ops/secrets/README.md). The unencrypted file is in
# .gitignore via the .env / *.env pattern.
#
# Per ADR-006 §1 and STRATEGIC-OVERVIEW §2: OVH Object Storage is the
# primary destination. OVH's S3 surface is AWS-compatible enough that
# WAL-G's S3 driver works without source-code changes, but a few
# endpoint/region knobs need explicit values — they are NOT the AWS
# defaults wal-g would pick.

# ---------------------------------------------------------------- target
# Per-client prefix — must match the IAM credential's prefix
# restriction (s3://lecrm-wal/<client-slug>/*). The trailing slash on
# the prefix is intentional; wal-g writes basebackups_005/, wal_005/,
# etc. as subkeys.
WALG_S3_PREFIX=s3://lecrm-wal/CLIENT_SLUG_HERE

# ---------------------------------------------------- OVH S3 endpoint
# Pick the OVH region matching the VPS placement (Gravelines for FR
# ICP). Endpoint URL is the High-Performance S3 surface; the legacy
# Cloud Archive S3 surface is at a different hostname and is NOT a
# drop-in for wal-push.
#
#   GRA (Gravelines, FR)  https://s3.gra.io.cloud.ovh.net
#   SBG (Strasbourg, FR)  https://s3.sbg.io.cloud.ovh.net
#   DE  (Frankfurt, DE)   https://s3.de.io.cloud.ovh.net
#
# Confirm the exact host for the chosen project in the OVH control
# panel under Public Cloud → Object Storage → "S3 URL". Endpoints can
# differ between High-Perf and Standard tiers.
AWS_ENDPOINT=https://s3.gra.io.cloud.ovh.net

# OVH requires path-style addressing (vs. virtual-host-style) for the
# High-Performance tier as of 2026-04 — wal-g defaults to virtual-host
# style which produces signature errors on OVH.
AWS_S3_FORCE_PATH_STYLE=true

# Region label MUST match the OVH region exactly. Signature v4 includes
# the region in the canonical request; a mismatch causes
# SignatureDoesNotMatch. OVH region codes are lowercase (gra, sbg, de).
AWS_REGION=gra

# ---------------------------------------------------- IAM credentials
# Per-client, prefix-restricted ("s3://lecrm-wal/<client-slug>/*"). Do
# NOT reuse credentials across clients; that would allow one tenant's
# compromised VPS to read another's WAL archive.
AWS_ACCESS_KEY_ID=REPLACE_WITH_OVH_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_OVH_SECRET_KEY

# ---------------------------------------------------- GPG encryption
# Armored PUBLIC key for lecrm-backup@gbconsult.me. Bake this here so
# wal-g encrypts every WAL segment and base-backup chunk before upload.
# OVH does not encrypt at rest by default; client-side GPG is what
# protects against bucket compromise / subpoena.
#
# To populate: cat deploy/postgres/gpg/lecrm-backup.pub.asc and paste
# the armored block here, OR use WALG_PGP_KEY_PATH to mount the file.
WALG_PGP_KEY_PATH=/etc/postgres/gpg/lecrm-backup.pub.asc

# Decryption key path — only set on a RESTORE host (recovery cluster).
# Production VPSes MUST NOT carry the private key; that lives on
# YubiKey + Bitwarden per ADR-006 §2.
# WALG_PGP_KEY_PATH_PRIVATE=/run/secrets/lecrm-backup.priv.asc

# ---------------------------------------------------- tunables
WALG_COMPRESSION_METHOD=brotli
WALG_UPLOAD_CONCURRENCY=4
WALG_DOWNLOAD_CONCURRENCY=4

# Optional: keep WAL upload-storage history sane. 30 days is a wide
# margin against any local PostgreSQL catch-up.
WALG_DELTA_MAX_STEPS=6
