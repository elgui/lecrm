# deploy/.env.dev.example — local development environment template.
#
# Copy to deploy/.env.dev and fill in secrets. The actual .env.dev is
# gitignored. For production, secrets are sourced from SOPS-encrypted
# files per tasket 20260510-162158-1023 (Sprint 3); this example is
# DEV-ONLY and the values used in real runs MUST NOT be reused in any
# environment a user can reach.
#
# Generate strong secrets with:
#   openssl rand -base64 48        # AUTHENTIK_SECRET_KEY, LECRM_SESSION_SECRET
#   openssl rand -hex 24           # POSTGRES passwords, BOOTSTRAP_PASSWORD
#   openssl rand -hex 32           # AUTHENTIK_BOOTSTRAP_TOKEN

# --- Postgres (leCRM control plane) ---
POSTGRES_SUPERUSER_PASSWORD=replace-me

# --- Postgres (Authentik) ---
AUTHENTIK_POSTGRES_PASSWORD=replace-me

# --- Authentik bootstrap ---
AUTHENTIK_SECRET_KEY=replace-me-with-48-bytes-base64
AUTHENTIK_BOOTSTRAP_EMAIL=dev@lecrm.test
AUTHENTIK_BOOTSTRAP_PASSWORD=replace-me
# Used for the initial admin API token; can rotate after first OIDC
# client is provisioned.
AUTHENTIK_BOOTSTRAP_TOKEN=replace-me-32-byte-hex

# --- LGTM (DEFERRED — not part of v0 default stack) ---
# Only needed if running compose/lgtm.yml for local deep-debugging.
# GRAFANA_ADMIN_PASSWORD=replace-me

# --- Caddy (DNS-01) ---
CLOUDFLARE_API_TOKEN=

# --- lecrm-api ---
LECRM_HTTP_ADDR=:8080
LECRM_DATABASE_URL=postgres://lecrm_api:replace-me@localhost:5432/lecrm?sslmode=disable
LECRM_SESSION_SECRET=replace-me-with-at-least-32-bytes
LECRM_COOKIE_DOMAIN_TLD=lecrm.test
LECRM_COOKIE_SECURE=false
LECRM_OIDC_ISSUER=http://localhost:9000/application/o/lecrm/
LECRM_OIDC_CLIENT_ID=lecrm-api
LECRM_OIDC_CLIENT_SECRET=replace-after-authentik-bootstrap
LECRM_OIDC_SCOPES=openid profile email
LECRM_OIDC_CALLBACK_PATH=/auth/callback
