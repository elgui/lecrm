# Automation run progress (transient, regenerated per run)
.automation-progress-*.json

# Unsubstituted template placeholder (artefact of project bootstrap)
{output_folder}/

# OS / editor noise
.DS_Store
*.swp
*.swo

# Go build artifacts (added pre-emptively for Sprint 2 onward)
/bin/
/vendor/
*.test
*.out
coverage.txt

# Node / Vite artifacts (apps/web — Sprint 2 onward)
node_modules/
apps/web/dist/
apps/web/.vite/

# Built SPA copied into the Go embed package (Sprint 9, go:embed). The
# real assets are build artifacts; only the .gitkeep sentinel is tracked so
# the //go:embed directive compiles in a fresh checkout.
apps/api/internal/spa/dist/*
!apps/api/internal/spa/dist/.gitkeep

# SOPS-decrypted .env should never be committed (encrypted .env.enc is fine)
.env
.env.*
!.env.example
!.env.*.enc
!.env.*.example

# WAL-G environment (deploy/postgres/walg.env) — holds OVH IAM creds.
# The .example template is committed; the decrypted form is local-only.
deploy/postgres/walg.env

# SOPS-decrypted secret manifests (tasket 20260510-162158-1023).
# Only the encrypted `.enc.yaml` form and the `.template` form may be
# committed. The plaintext intermediate `secrets.yaml` (between
# template-copy and sops-encrypt) MUST stay local.
secrets/clients/*/secrets.yaml
secrets/operator/secrets.yaml
!secrets/clients/_template/secrets.yaml.template
!secrets/operator/secrets.yaml.template

# Smoke-test transient artifacts
/tmp/lecrm-smoke-*
.archexplorer/

# Local Claude Code session config (empty/personal, not project-shared)
.claude/settings.json

# Compiled admin CLI binary (built locally; not for source tree)
apps/admin/lecrm-admin

# SDL-MCP per-project graph DB
.sdl-mcp/
